{
    "name": "rushing/laravel-marquee",
    "description": "Site-mode state machine for Laravel + Inertia apps. Generalizes coming-soon / maintenance / preview into five literal modes (live, soon, maintenance, preview, down), flippable at runtime with no redeploy or config:cache clear. The theater marquee out front, independent of whether the building is operating inside.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "inertiajs/inertia-laravel": "^1.0|^2.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Rushing\\Marquee\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\Marquee\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "Rushing\\Marquee\\MarqueeServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "pint": "@php -d memory_limit=512M vendor/bin/pint",
        "test": "@php vendor/bin/pest"
    }
}
